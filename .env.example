VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_ALPHA_VANTAGE_API_KEY=
# 選填：僅 server 用 Alpha Key（不進前端）；未填時 server 仍會讀取上方的 VITE_ALPHA_VANTAGE_API_KEY
ALPHA_VANTAGE_API_KEY=
# 選填：瀏覽器直連 Finnhub（Key 會暴露在前端 bundle，建議優先用下方 FINNHUB_API_KEY 僅給 server）
# 註冊：https://finnhub.io/register
VITE_FINNHUB_API_KEY=
# 選填：僅給 server/index.js 使用（npm run server），Yahoo 失敗時自動改打 Finnhub
FINNHUB_API_KEY=
# 選填：靜態部署時報價 API 的網址原點（不含尾隨斜線），需實作 GET /api/quote?symbol=
VITE_QUOTE_API_BASE=
VITE_ENABLE_AUTH_WHITELIST=false
VITE_AUTH_WHITELIST_EMAILS=y.chengju@gmail.com
