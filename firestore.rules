rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidTrade(data) {
      return data.keys().hasOnly([
          'symbol',
          'action',
          'quantity',
          'price',
          'tradedAt',
          'note',
          'createdAt'
        ]) &&
        data.symbol is string &&
        data.symbol.size() > 0 &&
        data.symbol.size() <= 16 &&
        data.action in ['BUY', 'SELL'] &&
        data.quantity is number &&
        data.quantity > 0 &&
        data.price is number &&
        data.price > 0 &&
        data.tradedAt is string &&
        data.createdAt is number &&
        (
          !('note' in data) ||
          (data.note is string && data.note.size() <= 200)
        );
    }

    match /trades/{tradeId} {
      allow read: if true;
      allow create: if isValidTrade(request.resource.data);
      allow delete: if true;
      allow update: if false;
    }
  }
}
